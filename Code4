#include <iostream>
#include <cstring>
#include <stdexcept>

// БАЗОВЫЙ КЛАСС (изменили private на protected)
class CallTracker {
protected:
    char* contactName;
    char* phoneNumber;
    double maxDuration;
    double minDuration;
    double totalDuration;
    int totalCalls;

public:
    CallTracker(const char* phone, const char* name = nullptr) {
        phoneNumber = new char[std::strlen(phone) + 1];
        std::strcpy(phoneNumber, phone);
        const char* finalName = (name != nullptr) ? name : phone;
        contactName = new char[std::strlen(finalName) + 1];
        std::strcpy(contactName, finalName);
        maxDuration = minDuration = totalDuration = 0;
        totalCalls = 0;
    }

    virtual ~CallTracker() { // virtual - важно для корректного удаления наследников
        delete[] contactName;
        delete[] phoneNumber;
    }

    // Метод вноса инфо (базовый)
    virtual void addCall(double duration) {
        if (duration < 0) throw std::domain_error("Отрицательное время");
        if (totalCalls == 0) {
            maxDuration = minDuration = duration;
        } else {
            if (duration > maxDuration) maxDuration = duration;
            if (duration < minDuration) minDuration = duration;
        }
        totalDuration += duration;
        totalCalls++;
    }

    virtual void displayInfo() const {
        std::cout << "Абонент: " << contactName << " [" << phoneNumber << "]" << std::endl;
        std::cout << "Звонков: " << totalCalls << ", Всего мин: " << totalDuration << std::endl;
    }
};

// ПРОИЗВОДНЫЙ КЛАСС: VIP-аналитика с рейтингом
class RatedCallTracker : public CallTracker {
private:
    double totalRating; // Сумма всех рейтингов

public:
    // Конструктор: вызываем конструктор базового класса
    RatedCallTracker(const char* phone, const char* name = nullptr) 
        : CallTracker(phone, name), totalRating(0) {}

    // Переопределенный метод вноса звонка (с рейтингом)
    void addCall(double duration, int rating) {
        // Проверка рейтинга (например, от 1 до 5)
        if (rating < 1 || rating > 5) throw std::out_of_range("Рейтинг должен быть от 1 до 5");
        
        // Вызываем базовую логику, чтобы не дублировать код
        CallTracker::addCall(duration); 
        
        totalRating += rating;
    }

    // Селектор среднего рейтинга
    double getAverageRating() const {
        if (totalCalls == 0) return 0;
        return totalRating / totalCalls;
    }

    // Измененный вывод на консоль
    void displayInfo() const override {
        CallTracker::displayInfo(); // Выводим базу
        std::cout << "Средний рейтинг важности: " << getAverageRating() << " / 5.0" << std::endl;
        std::cout << "---------------------------" << std::endl;
    }
};

int main() {
    try {
        // Создаем VIP-абонента
        RatedCallTracker vipContact("+79997771122", "Elon Musk");

        // Вносим звонки с рейтингом
        vipContact.addCall(15.0, 5); // Очень важный звонок
        vipContact.addCall(2.5, 3);  // Обычный звонок
        vipContact.addCall(45.0, 5); // Мега-важный звонок

        // Вывод всей инфо
        vipContact.displayInfo();

    } catch (const std::exception& e) {
        std::cerr << "Ошибка в системе: " << e.what() << std::endl;
    }
    return 0;
}

